<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
body {
    margin: 0;
    background: transparent;
    font-family: Arial, sans-serif;
    text-align: center;
}

.city {
    font-size: 12px;
    font-weight: bold;
    letter-spacing: 1px;
    opacity: 0.7;
}

.time {
    font-size: 42px;
    font-weight: bold;
    line-height: 1;
}

.date {
    font-size: 11px;
    opacity: 0.6;
}
</style>
</head>
<body>

<div class="city">PERTH</div>
<div class="time" id="time"></div>
<div class="date" id="date"></div>

<script>
function updateClock() {
    const now = new Date();

    document.getElementById("time").innerHTML =
        now.toLocaleTimeString("en-AU", {
            timeZone: "Australia/Perth",
            hour: "2-digit",
            minute: "2-digit",
            hour12: false
        });

    document.getElementById("date").innerHTML =
        now.toLocaleDateString("en-AU", {
            timeZone: "Australia/Perth",
            weekday: "short",
            day: "numeric",
            month: "short"
        });
}

updateClock();
setInterval(updateClock, 1000);
</script>

</body>
</html>
